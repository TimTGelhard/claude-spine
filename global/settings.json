{
  "permissions": {
    "allow": [
      "Bash(ls:*)",
      "Bash(pwd)",
      "Bash(cd:*)",
      "Bash(cat:*)",
      "Bash(mkdir:*)",
      "Bash(touch:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(echo:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(tree:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git pull:*)",
      "Bash(git stash:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(pip:*)",
      "Bash(pip3:*)",
      "Bash(pytest:*)",
      "Bash(uv:*)",
      "Bash(poetry:*)",
      "Bash(venv:*)",
      "Bash(source:*)",
      "Bash(node:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(pnpm:*)",
      "Bash(yarn:*)",
      "Bash(open:*)",
      "Bash(code:*)",
      "Bash(which:*)",
      "Bash(whereis:*)",
      "Bash(lsof:*)",
      "Bash(ps:*)",
      "Bash(supabase status)",
      "Bash(supabase migration list:*)",
      "Bash(supabase db diff:*)",
      "Bash(supabase gen types:*)",
      "Bash(vercel ls:*)",
      "Bash(vercel inspect:*)",
      "Bash(vercel logs:*)",
      "Bash(vercel env ls:*)",
      "Bash(vercel project ls:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh issue view:*)",
      "Bash(gh issue list:*)",
      "Bash(gh repo view:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Bash(claude mcp list)",
      "Bash(claude plugins list)",
      "Bash(lighthouse:*)",
      "Read(**)",
      "Write(**)",
      "Edit(**)",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:claude.com)",
      "WebFetch(domain:code.claude.com)",
      "WebFetch(domain:developers.google.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:stackoverflow.com)",
      "WebFetch(domain:supabase.com)",
      "WebFetch(domain:vercel.com)",
      "WebFetch(domain:nextjs.org)",
      "WebFetch(domain:react.dev)",
      "WebFetch(domain:tailwindcss.com)",
      "WebFetch(domain:context7.com)",
      "WebSearch"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(sudo:*)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(**/.env)",
      "Read(**/credentials.json)",
      "Read(**/*_secret*)",
      "Read(**/*token*)",
      "Write(./.env)",
      "Write(**/.env)"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(git reset --hard:*)",
      "Bash(git branch -D:*)",
      "Bash(npm publish:*)",
      "Bash(pip install:*)",
      "Bash(npm install:*)"
    ],
    "defaultMode": "auto"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git add*)",
            "command": "${HOME}/.claude/hooks/block-env-staging.sh",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "vercel@claude-plugins-official": true
  },
  "effortLevel": "high",
  "autoCompactWindow": 180000,
  "theme": "dark",
  "skipAutoPermissionPrompt": true
}
