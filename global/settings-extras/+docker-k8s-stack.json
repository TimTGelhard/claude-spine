{
  "_comment": "Merge into ~/.claude/settings.json when you containerize. Adds Docker + Docker Compose + Kubernetes (kubectl, helm) read patterns + Docker Hub / k8s docs WebFetch. Destructive patterns (docker rm, docker rmi, kubectl delete, helm uninstall) are intentionally NOT pre-allowed.",
  "permissions": {
    "allow": [
      "Bash(docker ps:*)",
      "Bash(docker images:*)",
      "Bash(docker logs:*)",
      "Bash(docker inspect:*)",
      "Bash(docker version:*)",
      "Bash(docker compose ps:*)",
      "Bash(docker compose logs:*)",
      "Bash(docker compose config:*)",
      "Bash(docker-compose ps:*)",
      "Bash(docker-compose logs:*)",
      "Bash(docker-compose config:*)",
      "Bash(kubectl get:*)",
      "Bash(kubectl describe:*)",
      "Bash(kubectl logs:*)",
      "Bash(kubectl version:*)",
      "Bash(kubectl config view:*)",
      "Bash(kubectl config get-contexts:*)",
      "Bash(helm list:*)",
      "Bash(helm status:*)",
      "Bash(helm version:*)",
      "Bash(minikube status:*)"
    ],
    "WebFetch": [
      "domain:docs.docker.com",
      "domain:hub.docker.com",
      "domain:kubernetes.io",
      "domain:helm.sh"
    ]
  }
}
