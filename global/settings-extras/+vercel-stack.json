{
  "_comment": "Merge into ~/.claude/settings.json when you deploy to Vercel. Adds Vercel CLI read+write patterns and Vercel platform docs WebFetch (incl. nextjs.org, which the neutral default no longer ships).",
  "permissions": {
    "allow": [
      "Bash(vercel ls:*)",
      "Bash(vercel inspect:*)",
      "Bash(vercel logs:*)",
      "Bash(vercel env ls:*)",
      "Bash(vercel project ls:*)",
      "Bash(vercel domains:*)",
      "Bash(vercel certs:*)",
      "Bash(vercel teams:*)",
      "Bash(vercel whoami:*)",
      "Bash(vercel link:*)",
      "Bash(vercel pull:*)",
      "Bash(vercel env pull:*)",
      "Bash(vercel build:*)",
      "Bash(vercel dev:*)"
    ],
    "WebFetch": [
      "domain:vercel.com",
      "domain:nextjs.org",
      "domain:vercel-storage.com",
      "domain:edge-config.com"
    ]
  }
}
