{
  "_comment": "Merge into ~/.claude/settings.json when Supabase is your backend. Adds Supabase CLI read+write patterns and Supabase docs WebFetch — the neutral default ships stack-agnostic and does NOT include any `supabase` commands or `supabase.com` WebFetch.",
  "permissions": {
    "allow": [
      "Bash(supabase status)",
      "Bash(supabase migration list:*)",
      "Bash(supabase db diff:*)",
      "Bash(supabase gen types:*)",
      "Bash(supabase start:*)",
      "Bash(supabase stop:*)",
      "Bash(supabase functions list:*)",
      "Bash(supabase functions deploy:*)",
      "Bash(supabase secrets list:*)",
      "Bash(supabase db reset:*)",
      "Bash(supabase db pull:*)",
      "Bash(supabase link:*)",
      "Bash(supabase login:*)",
      "Bash(supabase projects list:*)"
    ],
    "WebFetch": [
      "domain:supabase.com",
      "domain:supabase.io"
    ]
  }
}
